jest.mock("react-chartjs-2", () => ({
  Doughnut: (props) => <div data-testid="mock-doughnut" aria-label={props["aria-label"] || "Doughnut Chart"} />,
  Line: (props) => <div data-testid="mock-line" aria-label={props["aria-label"] || "Line Chart"} />,
}));

import React from "react";
import { render, screen, fireEvent, act, waitFor } from "@testing-library/react";
import { axe, toHaveNoViolations } from "jest-axe";
import AnalyticsModal from "../AnalyticsModal";
import { AnalyticsProvider } from "../AnalyticsContext";
import { BadgeProvider } from "../BadgeContext";

jest.mock("../firebase/helpersFirebase.js", () => ({
  fetchLeaderboard: jest.fn(async (limit = 10) => [
    { id: 'user1', name: 'Test User 1', points: 100, badges: [{}, {}] },
    { id: 'user2', name: 'Test User 2', points: 80, badges: [{}] },
  ]),
}));

expect.extend(toHaveNoViolations);

describe("AnalyticsModal", () => {
  const defaultProps = {
    open: true,
    onClose: jest.fn(),
    analytics: { correct: 5, total: 10, streak: 2 },
    quizHistory: [{ score: 5, total: 10, date: Date.now(), streak: 2 }],
    masteryHistory: [{ date: Date.now(), avgMastery: 50 }],
    errorMap: {},
    questions: [
      { id: "q1", stats: { correct: 1, incorrect: 0 }, topic: "A" },
      { id: "q2", stats: { correct: 0, incorrect: 1 }, topic: "B" }
    ],
    badges: [
      { id: "b1", name: "Badge 1", earned: true },
      { id: "b2", name: "Badge 2", earned: false }
    ]
  };

  function renderWithProviders(ui) {
    return render(
      <AnalyticsProvider>
        <BadgeProvider>
          {ui}
        </BadgeProvider>
      </AnalyticsProvider>
    );
  }

  it("renders analytics modal with stats", async () => {
    await act(async () => {
      renderWithProviders(<AnalyticsModal {...defaultProps} loading={false} />);
    });
    await screen.findByText("Analytics");
    expect(screen.getByText(/Quiz Stats/i)).toBeInTheDocument();
    expect(screen.getByText(/Total Questions/i)).toBeInTheDocument();
    expect(screen.getByText(/Badges Earned/i)).toBeInTheDocument();
  });

  it("renders empty state if no questions", async () => {
    await act(async () => {
      renderWithProviders(<AnalyticsModal {...defaultProps} questions={[]} loading={false} />);
    });
    await screen.findByText(/No analytics data available/i);
    expect(screen.getByText(/No analytics data available/i)).toBeInTheDocument();
  });

  it("calls onClose when close button is clicked", async () => {
    await act(async () => {
      renderWithProviders(<AnalyticsModal {...defaultProps} />);
    });
    fireEvent.click(screen.getByRole("button", { name: /close/i }));
    expect(defaultProps.onClose).toHaveBeenCalled();
  });

  it("traps focus and closes on Escape key", async () => {
    await act(async () => {
      renderWithProviders(<AnalyticsModal {...defaultProps} />);
    });
    const dialog = screen.getByRole("dialog");
    dialog.focus();
    fireEvent.keyDown(dialog, { key: "Escape" });
    expect(defaultProps.onClose).toHaveBeenCalled();
  });

  it("shows loading state", async () => {
    await act(async () => {
      renderWithProviders(<AnalyticsModal {...defaultProps} loading={true} />);
    });
    expect(screen.getByText(/loading/i)).toBeInTheDocument();
  });

  it("shows error state and retry button", async () => {
    await act(async () => {
      renderWithProviders(<AnalyticsModal {...defaultProps} questions={[]} error="Network error" loading={false} />);
    });
    await screen.findByText("Network error");
    expect(screen.getByText("Network error")).toBeInTheDocument();
  });

  it("renders empty state if no questions", async () => {
    await act(async () => {
      renderWithProviders(<AnalyticsModal {...defaultProps} questions={[]} error={undefined} loading={false} />);
    });
    await screen.findByText(/No analytics data available/i);
    expect(screen.getByText(/No analytics data available/i)).toBeInTheDocument();
  });

  it("has correct accessibility attributes", async () => {
    await act(async () => {
      renderWithProviders(<AnalyticsModal {...defaultProps} loading={false} />);
    });
    const dialog = await screen.findByRole("dialog");
    expect(dialog).toHaveAttribute("aria-modal", "true");
    expect(dialog).toHaveAttribute("aria-labelledby");
    expect(dialog).toHaveAttribute("aria-describedby");
  });

  it("has no accessibility violations", async () => {
    const { container } = renderWithProviders(<AnalyticsModal {...defaultProps} />);
    const results = await axe(container);
    expect(results).toHaveNoViolations();
  });

  it("shows error fallback with role alert", async () => {
    await act(async () => {
      renderWithProviders(<AnalyticsModal {...defaultProps} questions={[]} error="Network error" loading={false} />);
    });
    await screen.findByRole("alert");
    expect(screen.getByRole("alert")).toBeInTheDocument();
    expect(screen.getByText("Network error")).toBeInTheDocument();
  });
});
